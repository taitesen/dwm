#!/usr/bin/env bash
pink="#EBBCBA"
green="#a3b238"

vol="$(wpctl get-volume @DEFAULT_AUDIO_SINK@)"

# If muted, print ≤░ΨΒ and exit.
[ "$vol" != "${vol%\[MUTED\]}" ] && printf "^c$green^^B1^ ≤░ΨΒ ^d^" && exit

vol="${vol#Volume: }"

split() {
	# For ommiting the . without calling and external program.
	IFS=$2
	set -- $1
	printf '%s' "$@"
}

vol="$(printf "%.0f" "$(split "$vol" ".")")"

case 1 in
	$((vol >= 70)) ) icon=" ΎΑρ " ;;
	$((vol >= 30)) ) icon=" ΎΑπ " ;;
	$((vol >= 1)) ) icon=" ΎΑο " ;;
	* ) printf "^c$green^^B1^ ≤░ΨΒ ^d^" && exit ;;
esac

printf "^B1^^c$green^$icon^d^ $vol%%"
