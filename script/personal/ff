#!/usr/bin/env bash

# Path to your bookmark file
bookmark_file="$HOME/.config/qutebrowser/quickmarks"

# Use fzf to select a bookmark
selected=$(bat "$bookmark_file" | fzf --preview="echo {} | cut -d' ' -f2")

# Extract the URL from the selected line
url=$(echo "$selected" | cut -d' ' -f2)

# Open the selected URL in Firefox
if [ -n "$url" ]; then
    firefox-developer-edition "$url" &
fi
